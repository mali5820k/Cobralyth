extern C int32 printf(string formatted_string, ...)

int32 main(string[] args) {
    int32[] values = [10, 20, 12]

    printf("length: %ld\n", values.length)
    printf("first: %d\n", values[0])
    printf("last: %d\n", values[2])

    values[1] += 22
    printf("middle: %d\n", values[1])

    return 0
}
