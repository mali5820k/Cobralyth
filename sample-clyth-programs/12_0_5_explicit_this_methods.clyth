extern C int32 printf(string fmt, ...)

struct Counter {
    private int32 value

    constructor() {
        this.value = 0
    }

    void add(int32 amount) {
        this.value += amount
    }

    int32 get() {
        return this.value
    }
}

int32 main(string[] args) {
    Counter counter
    counter.add(40)
    counter.add(2)
    printf("explicit this counter: %d\n", counter.get())
    return 0
}
