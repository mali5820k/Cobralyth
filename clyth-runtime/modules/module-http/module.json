{
  "name": "http",
  "version": "0.5.0-alpha",
  "kind": "runtime-module",
  "exports": [
    "http.clyth"
  ],
  "dependencies": ["router"],
  "wrapper": { "license": "MIT" },
  "c_bindings": [
    {
      "name": "clyth_http",
      "enabled": true,
      "backend": "Clyth POSIX HTTP/Router C Binding",
      "license": "MIT",
      "source_directory": "../../c-bindings/http",
      "architectures": {
        "x86_64": { "archive": "x86_64/libclyth_http.a" },
        "aarch64": { "archive": "aarch64/libclyth_http.a" },
        "arm64": { "archive": "arm64/libclyth_http.a" }
      }
    }
  ],
  "notes": "0.5.0 exposes router/config/server handles and route callback registration. Full request parsing and event-loop ownership remain runtime work."
}
