int32 main() {
    uint8 max_u8 = 255
    uint8 wrapped_u8 = max_u8 + 1

    if wrapped_u8 != 0 {
        return 1
    }

    uint8 zero_u8 = 0
    uint8 under_u8 = zero_u8 - 1

    if under_u8 != 255 {
        return 2
    }

    int8 max_i8 = 127
    int8 wrapped_i8 = max_i8 + 1

    if wrapped_i8 != -128 {
        return 3
    }

    return 0
}
